# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets. Use .env.example as a template.
.env
.env.*
!.env.example

# local SQLite database (we use Neon Postgres in production)
/db/*.db
/db/*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only files
local-*
.claude
.z-ai-config
.zscripts
dev.log
dev.out.log
server.log
test
prompt

# Skills directory (internal tooling)
/skills/

# Upload directory (source JSON files — operator-managed, not committed)
/upload/

# Download directory (screenshots, generated docs — not part of source)
/download/

# Examples (reference code, not part of the app)
/examples/

# Mini-services (separate projects)
/mini-services/
