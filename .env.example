# Environment variables — copy this file to .env and fill in your values.
# DO NOT commit the real .env file (it's gitignored).

# Neon Postgres connection string (production)
# Get yours from https://console.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Google OAuth — created in Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
# IMPORTANT: Change NEXTAUTH_URL to your production URL before deploying!
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.com

# Google Gemini (for AI-powered content quality assessment)
# Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional: model to use (default: gemini-2.0-flash)
AI_MODEL=gemini-2.0-flash

# Sentry — error tracking (get your DSN from https://sentry.io)
# Only needed in production; the app works fine without it
SENTRY_DSN=
# Sentry org/project slugs (for source map uploads)
SENTRY_ORG=
SENTRY_PROJECT=
# Sentry auth token (for CI source map uploads)
# Generate at: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
